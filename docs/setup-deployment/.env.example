# ============================================================================
# .env.example - TEMPLATE for environment variables
# ============================================================================
#
# CRITICAL: This is a TEMPLATE. Copy to .env and fill with REAL values.
# NEVER commit .env with actual secrets to GitHub!
#
# Setup:
# 1. cp .env.example .env
# 2. Edit .env with your actual API keys
# 3. Add .env to .gitignore (already done)
#
# ============================================================================

# ============================================================================
# ANTHROPIC API (MOST CRITICAL - KEEP SECURE!)
# ============================================================================
# Get from: https://console.anthropic.com/
# Format: sk-ant-xxxxx...
# NEVER share this key!

ANTHROPIC_API_KEY=sk-ant-replace_with_your_actual_key_xxx

# ============================================================================
# FASTAPI CONFIGURATION
# ============================================================================

FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_RELOAD=true

# ============================================================================
# STREAMLIT CONFIGURATION
# ============================================================================

STREAMLIT_LOGGER_LEVEL=info
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=false

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO
APP_NAME=Loan Approval System
APP_VERSION=2.0.0

# ============================================================================
# DATABASE (if using)
# ============================================================================

DATABASE_URL=sqlite:///./loan_system.db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=loan_approval
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# ============================================================================
# SECURITY (KEEP SECURE!)
# ============================================================================

SECRET_KEY=your_random_secret_key_min_32_chars_xxxxxxxxx
JWT_SECRET_KEY=your_jwt_secret_key_xxxxxxxxx
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================================
# AWS (if using AWS services - KEEP SECURE!)
# ============================================================================

AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_bucket_name

# ============================================================================
# LANGCHAIN CONFIGURATION
# ============================================================================

LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key

# ============================================================================
# MCP CONFIGURATION
# ============================================================================

MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=3000
